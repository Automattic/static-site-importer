{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "static-site-importer/solved-site-promotion-receipt/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "candidate", "runtime", "corpus", "gates", "evidence"],
  "properties": {
    "schema": { "const": "static-site-importer/solved-site-promotion-receipt/v1" },
    "status": { "const": "accepted" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["static_site_importer_sha", "blocks_engine_sha"],
      "properties": {
        "static_site_importer_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "blocks_engine_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_version", "php_version", "wordpress_version", "homeboy_version", "homeboy_sha256", "homeboy_extensions_ref", "wp_codebox_version", "wp_codebox_sha256"],
      "properties": {
        "node_version": { "type": "string", "minLength": 1 },
        "php_version": { "type": "string", "minLength": 1 },
        "wordpress_version": { "type": "string", "minLength": 1 },
        "homeboy_version": { "type": "string", "minLength": 1 },
        "homeboy_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "homeboy_extensions_ref": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "wp_codebox_version": { "type": "string", "minLength": 1 },
        "wp_codebox_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture_root_tree_sha", "solved_fixture_count", "selected_fixture_ids", "selected_fixture_count"],
      "properties": {
        "fixture_root_tree_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "solved_fixture_count": { "type": "integer", "minimum": 1 },
        "selected_fixture_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "selected_fixture_count": { "type": "integer", "minimum": 1 }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matrix", "solved_candidate", "materialization_receipts", "editor", "visual", "native_blocks", "artifacts"],
      "properties": {
        "matrix": { "const": "passed" },
        "solved_candidate": { "const": "passed" },
        "materialization_receipts": { "const": "passed" },
        "editor": { "const": "passed" },
        "visual": { "const": "passed" },
        "native_blocks": { "const": "passed" },
        "artifacts": { "const": "passed" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_url", "artifact_manifest_url", "artifacts"],
      "properties": {
        "run_url": { "type": "string", "pattern": "^https://github\\.com/.+/actions/runs/[0-9]+$" },
        "artifact_manifest_url": { "type": "string", "pattern": "^https://github\\.com/.+/actions/runs/[0-9]+#artifacts$" },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "bytes"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "bytes": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
